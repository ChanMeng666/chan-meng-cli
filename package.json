{
  "name": "chan-meng",
  "version": "2.0.1",
  "description": "An interactive CLI to meet Chan Meng and explore her minimalist philosophy",
  "type": "module",
  "main": "dist/cli.js",
  "bin": {
    "chan-meng": "dist/cli.js"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "preferGlobal": false,
  "files": [
    "dist/",
    "README.md"
  ],
  "scripts": {
    "build": "node esbuild.config.js",
    "dev": "node esbuild.config.js --watch",
    "start": "node dist/cli.js",
    "prepublishOnly": "npm run build && npm test",
    "test": "cross-env NODE_OPTIONS=--experimental-vm-modules jest",
    "test:watch": "cross-env NODE_OPTIONS=--experimental-vm-modules jest --watch",
    "test:coverage": "cross-env NODE_OPTIONS=--experimental-vm-modules jest --coverage",
    "validate-content": "node scripts/validate-content.js"
  },
  "keywords": [
    "cli",
    "minimalism",
    "interactive",
    "personal",
    "biography",
    "storytelling",
    "terminal",
    "npx"
  ],
  "author": {
    "name": "Chan Meng",
    "email": "chanmeng.dev@gmail.com",
    "url": "https://github.com/ChanMeng666"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ChanMeng666/chan-meng-cli.git"
  },
  "bugs": {
    "url": "https://github.com/ChanMeng666/chan-meng-cli/issues"
  },
  "homepage": "https://github.com/ChanMeng666/chan-meng-cli#readme",
  "dependencies": {
    "@inkjs/ui": "^2.0.0",
    "conf": "^11.0.2",
    "ink": "^7.0.1",
    "react": "^19.2.5"
  },
  "devDependencies": {
    "ajv": "^8.17.1",
    "cross-env": "^10.1.0",
    "esbuild": "^0.28.0",
    "esbuild-jest": "^0.5.0",
    "ink-testing-library": "^4.0.0",
    "jest": "^29.7.0"
  }
}
